# Admin token for credentials API (auto-generated if not set)
# ADMIN_TOKEN=

# ── Shopify (Custom App OAuth) ─────────────────────────────
# 1. Shopify管理画面 > 設定 > アプリと販売チャネル > アプリを開発 > カスタムアプリを作成
# 2. Client ID (API Key) と Client Secret (API Secret Key) を入力
# 3. UIからOAuth認証してAccess Tokenを自動取得
# SHOPIFY_STORE_DOMAIN=myshop.myshopify.com
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
# SHOPIFY_ACCESS_TOKEN=  (OAuth で自動設定)

# ── Rakuten (楽天市場) ─────────────────────────────────────
# 公開API: https://webservice.rakuten.co.jp/ でアプリ登録 → アプリIDを取得
# RMS API: RMS管理画面 > 各種設定 > API設定 で発行
# RAKUTEN_APP_ID=
# RAKUTEN_SERVICE_SECRET=  (RMS用)
# RAKUTEN_LICENSE_KEY=     (RMS用)

# ── Amazon SP-API ─────────────────────────────────────────
# 1. Seller Central > アプリ開発 でアプリ登録
# 2. LWA認証情報 (Client ID / Secret) を取得
# 3. SP-API認可フローでRefresh Tokenを取得
# AMAZON_CLIENT_ID=
# AMAZON_CLIENT_SECRET=
# AMAZON_REFRESH_TOKEN=
# AMAZON_MARKETPLACE_ID=A1VC38T7YXB528

# ── Yahoo!ショッピング (OAuth) ────────────────────────────
# 1. https://e.developer.yahoo.co.jp/ でアプリケーション登録
# 2. Client ID / Secret を取得
# 3. UIからOAuth認証してAccess Tokenを自動取得
# YAHOO_CLIENT_ID=
# YAHOO_CLIENT_SECRET=
# YAHOO_SELLER_ID=
# YAHOO_ACCESS_TOKEN=      (OAuth で自動設定)
# YAHOO_REFRESH_TOKEN=     (OAuth で自動設定)

# ── Google OAuth (BigQuery認証用) ──────────────────────────
# GCPコンソール > APIとサービス > 認証情報 > OAuth 2.0 クライアントID で作成
# リダイレクトURI: http://localhost:8000/api/bigquery/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
